# 规范 arm64 镜像清单 (canonical) — docker-compose.yaml 通过 --env-file .env 读取。
# 单一构建来源:
#   primihub-platform / primihub-web  <- 本仓库 .github/workflows/docker.yaml (多架构 -> ACR)
#   primihub-meta                     <- primihub-meta 仓库 release.yaml (多架构 -> ACR)
#   primihub-node                     <- primihub 仓库 release.yaml + Dockerfile.ci (多架构 -> ACR)
# 基础设施为各自 arm64 tag: mysql 无 arm64 -> mariadb; nacos 仅 v2.4.3-arm64(schema 与 x86 v2.0.4 异)。
# platform/web 的 tag 应与 docker.yaml 发布时推的 git tag 对齐(下面用已验证的 2026.07.13)。

# --- primihub 自研镜像 (arm64 / 多架构) ---
PRIMIHUB_PLATFORM=registry.cn-beijing.aliyuncs.com/primihub/primihub-platform:2026.07.15
PRIMIHUB_WEB_MANAGE=registry.cn-beijing.aliyuncs.com/primihub/primihub-web:2026.07.15
PRIMIHUB_META=registry.cn-beijing.aliyuncs.com/primihub/primihub-meta:2026.07.15
PRIMIHUB_NODE=registry.cn-beijing.aliyuncs.com/primihub/primihub-node:2026.07.15

# --- 依赖中间件 (arm64) ---
MYSQL_IMAGE=registry.cn-beijing.aliyuncs.com/primihub/mariadb:10.11-arm64
REDIS_IMAGE=registry.cn-beijing.aliyuncs.com/primihub/redis:7-arm64
NACOS_IMAGE=registry.cn-beijing.aliyuncs.com/primihub/nacos-server:v2.4.3-arm64
RABBITMQ_IMAGE=registry.cn-beijing.aliyuncs.com/primihub/rabbitmq:3.6.15-management-arm64
LOKI_IMAGE=registry.cn-beijing.aliyuncs.com/primihub/loki:2.9.0-arm64
