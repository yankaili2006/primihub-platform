<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.primihub.biz.repository.primarydb.data.DataUnionPrRepository">
    <insert id="saveDataUnion" keyProperty="id" useGeneratedKeys="true" parameterType="com.primihub.biz.entity.data.po.DataUnion">
        insert into data_union (own_organ_id,own_resource_id,own_keyword,other_organ_id,other_resource_id,other_keyword,output_file_path_type,output_no_repeat,tag,result_name,output_format,result_organ_ids,tee_organ_id,remarks,user_id,is_del,create_date,update_date)
        values (#{ownOrganId},#{ownResourceId},#{ownKeyword},#{otherOrganId},#{otherResourceId},#{otherKeyword},#{outputFilePathType},#{outputNoRepeat},#{tag},#{resultName},#{outputFormat},#{resultOrganIds},#{teeOrganId},#{remarks},#{userId},0,now(),now())
    </insert>
    <insert id="saveDataUnionTask" keyProperty="id" useGeneratedKeys="true" parameterType="com.primihub.biz.entity.data.po.DataUnionTask">
        insert into data_union_task (union_id,task_id,task_state,ascription,ascription_type,file_rows,file_path,is_del,create_date,update_date)
        values (#{unionId},#{taskId},#{taskState},#{ascription},#{ascriptionType},#{fileRows},#{filePath},0,now(),now())
    </insert>

    <update id="updateDataUnionTask" parameterType="com.primihub.biz.entity.data.po.DataUnionTask">
        update data_union_task
        <set>
            <if test="unionId!=null">union_id = #{unionId},</if>
            <if test="taskId!=null">task_id = #{taskId},</if>
            <if test="taskState!=null">task_state = #{taskState},</if>
            <if test="ascription!=null">ascription = #{ascription},</if>
            <if test="filePath!=null">file_path = #{filePath},</if>
            <if test="fileRows!=null">file_rows = #{fileRows},</if>
            <if test="fileContent!=null">file_content = #{fileContent},</if>
            update_date = now()
        </set>
        where id = #{id}
    </update>
    <update id="updateDataUnion">
        update data_union set result_name = #{resultName} where id = #{id}
    </update>
    <delete id="delUnionTask">
        delete from data_union_task where id = #{taskId}
    </delete>
    <delete id="delUnion">
        delete from data_union where id = #{unionId}
    </delete>
</mapper>
