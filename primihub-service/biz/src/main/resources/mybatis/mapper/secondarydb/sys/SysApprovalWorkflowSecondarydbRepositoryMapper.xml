<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.primihub.biz.repository.secondarydb.sys.SysApprovalWorkflowSecondarydbRepository">
    <sql id="Base_Column_List">id,workflow_name,workflow_desc,approval_type,approval_levels,approvers,status,c_time</sql>
    <select id="selectList" resultType="com.primihub.biz.entity.sys.po.SysApprovalWorkflow">
        SELECT <include refid="Base_Column_List"/> FROM sys_approval_workflow WHERE is_del=0 ORDER BY c_time DESC
    </select>
    <select id="selectById" resultType="com.primihub.biz.entity.sys.po.SysApprovalWorkflow">
        SELECT <include refid="Base_Column_List"/> FROM sys_approval_workflow WHERE id=#{id} AND is_del=0
    </select>
</mapper>